{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/reservations", "destination": "/prenota", "permanent": true },
    { "source": "/event-list", "destination": "/eventi", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|images/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
